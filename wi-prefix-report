set -euo pipefail

import argparse
import os
import re
from typing import Dict, List, Optional

from opensearchpy import OpenSearch
from opensearchpy.connection import RequestsHttpConnection


SIZE_RE = re.compile(r"^\s*([0-9]*\.?[0-9]+)\s*([kmgtp]?b)?\s*$", re.IGNORECASE)
UNIT_MULT = {
	None: 1,
	"b": 1,
	"kb": 1024,
	"mb": 1024**2,
	"gb": 1024**3,
	"tb": 1024**4,
	"pb": 1024**5,
}


def parse_auth_file(path: str) -> Dict[str, str]:
	if not path:
		raise ValueError("Auth file path is required")
	if not os.path.exists(path):
		raise FileNotFoundError(f"Auth file not found: {path}")

	cfg: Dict[str, str] = {}
	with open(path, "r", encoding="utf-8") as f:
		for raw in f:
			line = raw.strip()
			if not line or line.startswith("#") or "=" not in line:
				continue
			k, v = line.split("=", 1)
			cfg[k.strip()] = v.strip()

	if not cfg.get("WIUSER") or not cfg.get("WIPASS"):
		raise ValueError("Missing WIUSER or WIPASS in auth file")

	cfg["WIPROTO"] = (cfg.get("WIPROTO") or "https").strip() or "https"
	cfg["WIHOST"] = (cfg.get("WIHOST") or "").strip() or "localhost"
	cfg["WIPORT"] = (cfg.get("WIPORT") or "9200").strip() or "9200"
	return cfg


def build_client(cfg: Dict[str, str]) -> OpenSearch:
	return OpenSearch(
		hosts=[{"host": cfg["WIHOST"], "port": int(cfg["WIPORT"])}],
		http_auth=(cfg["WIUSER"], cfg["WIPASS"]),
		use_ssl=cfg["WIPROTO"].lower() == "https",
		verify_certs=False,
		ssl_show_warn=False,
		connection_class=RequestsHttpConnection,
		timeout=30,
		max_retries=3,
		retry_on_timeout=True,
	)


def parse_size_to_bytes(s: Optional[str]) -> int:
	if not s:
		return 0
	m = SIZE_RE.match(str(s))
	if not m:
		return 0
	val = float(m.group(1))
	unit = m.group(2).lower() if m.group(2) else None
	return int(val * UNIT_MULT.get(unit, 1))


def bytes_to_human_rounded_tenth(n: int) -> str:
	units = ["B", "KiB", "MiB", "GiB", "TiB", "PiB"]
	x = float(n)
	i = 0
	while x >= 1024.0 and i < len(units) - 1:
		x /= 1024.0
		i += 1
	return f"{x:.1f} {units[i]}"


def read_prefixes(prefix_args: List[str], prefix_file: Optional[str]) -> List[str]:
	prefixes: List[str] = []
	for p in prefix_args:
		if p and p.strip():
			prefixes.append(p.strip())

	if prefix_file:
		with open(prefix_file, "r", encoding="utf-8") as f:
			for raw in f:
				line = raw.strip()
				if not line or line.startswith("#"):
					continue
				prefixes.append(line)

	out: List[str] = []
	seen = set()
	for p in prefixes:
		if p not in seen:
			out.append(p)
			seen.add(p)
	return out


def get_index_metrics(client: OpenSearch) -> Dict[str, Dict[str, int]]:
	rows = client.cat.indices(format="json", h="index,store.size,pri.store.size,pri,rep")
	metrics: Dict[str, Dict[str, int]] = {}
	for r in rows:
		name = r.get("index")
		if not name:
			continue
		metrics[name] = {
			"store_bytes_total": parse_size_to_bytes(r.get("store.size")),
			"store_bytes_primary": parse_size_to_bytes(r.get("pri.store.size")),
			"primaries": int(r.get("pri") or 0),
			"replicas": int(r.get("rep") or 0),
		}
	return metrics


def get_shard_copies_by_index(client: OpenSearch) -> Dict[str, int]:
	rows = client.cat.shards(format="json", h="index")
	counts: Dict[str, int] = {}
	for r in rows:
		idx = r.get("index")
		if not idx:
			continue
		counts[idx] = counts.get(idx, 0) + 1
	return counts


def format_table(rows: List[List[str]]) -> str:
	col_count = len(rows[0])
	widths = [max(len(str(row[i])) for row in rows) for i in range(col_count)]

	out_lines = []
	for ri, row in enumerate(rows):
		formatted_cells = []
		for i in range(col_count):
			cell = str(row[i])
			if i == 0:
				formatted_cells.append(cell.ljust(widths[i]))
			else:
				formatted_cells.append(cell.rjust(widths[i]))
		out_lines.append("  ".join(formatted_cells))
		if ri == 0:
			out_lines.append("  ".join("-" * widths[i] for i in range(col_count)))
	return "\n".join(out_lines)


def pct_whole(part: int, whole: int) -> str:
	if whole <= 0:
		return "0%"
	return f"{round((part / whole) * 100):d}%"


def main() -> int:
	ap = argparse.ArgumentParser()
	ap.add_argument("--auth-file", required=True)
	ap.add_argument("--prefix", action="append", default=[])
	ap.add_argument("--prefix-file")
	ap.add_argument("--PREFIX-FILE")
	ap.add_argument("--human", action="store_true")
	args = ap.parse_args()

	prefix_file = args.prefix_file or args.PREFIX_FILE
	prefixes = read_prefixes(args.prefix, prefix_file)
	if not prefixes:
		raise SystemExit("No prefixes provided.")

	cfg = parse_auth_file(args.auth_file)
	client = build_client(cfg)

	per_index = get_index_metrics(client)
	shard_copies = get_shard_copies_by_index(client)

	per_prefix: List[Dict[str, int | str]] = []

	total_indexes = 0
	total_primary_shards = 0
	total_all_shards = 0
	total_primary_bytes = 0
	total_bytes = 0

	for p in prefixes:
		matched = [idx for idx in per_index.keys() if idx.startswith(p)]
		matched.sort()

		index_count = len(matched)
		primary_shards = sum(per_index[idx]["primaries"] for idx in matched)
		all_shards = sum(shard_copies.get(idx, 0) for idx in matched)
		primary_bytes = sum(per_index[idx]["store_bytes_primary"] for idx in matched)
		total_bytes_row = sum(per_index[idx]["store_bytes_total"] for idx in matched)

		total_indexes += index_count
		total_primary_shards += primary_shards
		total_all_shards += all_shards
		total_primary_bytes += primary_bytes
		total_bytes += total_bytes_row

		per_prefix.append(
			{
				"prefix": p,
				"indexes": index_count,
				"primary_shards": primary_shards,
				"all_shards": all_shards,
				"primary_bytes": primary_bytes,
				"total_bytes_row": total_bytes_row,
			}
		)

	header = [
		"Prefix",
		"Indexes",
		"Primary Shards",
		"All Shards",
		"% Total Shards",
		"Primary Shard Space",
		"Total Space",
		"% Total Space",
	]
	table_rows: List[List[str]] = [header]

	for r in per_prefix:
		table_rows.append(
			[
				str(r["prefix"]),
				str(r["indexes"]),
				str(r["primary_shards"]),
				str(r["all_shards"]),
				pct_whole(int(r["all_shards"]), total_all_shards),
				bytes_to_human_rounded_tenth(int(r["primary_bytes"])) if args.human else str(r["primary_bytes"]),
				bytes_to_human_rounded_tenth(int(r["total_bytes_row"])) if args.human else str(r["total_bytes_row"]),
				pct_whole(int(r["total_bytes_row"]), total_bytes),
			]
		)

	table_rows.append(["-" * len(h) for h in header])

	table_rows.append(
		[
			"TOTAL",
			str(total_indexes),
			str(total_primary_shards),
			str(total_all_shards),
			pct_whole(total_all_shards, total_all_shards),
			bytes_to_human_rounded_tenth(total_primary_bytes) if args.human else str(total_primary_bytes),
			bytes_to_human_rounded_tenth(total_bytes) if args.human else str(total_bytes),
			pct_whole(total_bytes, total_bytes),
		]
	)

	print(format_table(table_rows))
	return 0


if __name__ == "__main__":
	raise SystemExit(main())
